# Dev mode: mock login without X credentials (set false for production)
DEV_MOCK_AUTH=true

# X (Twitter) OAuth 2.0 — https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=your_client_id
X_CLIENT_SECRET=your_client_secret

# Must match your X app callback URL: http://localhost:5173/api/auth/x/callback
X_REDIRECT_URI=http://localhost:5173/api/auth/x/callback

# Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_32_byte_hex_string

# API port (proxied through Vite in dev)
API_PORT=3001

# Frontend URL (for CORS + redirects)
FRONTEND_URL=http://localhost:5173