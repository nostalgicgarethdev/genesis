# Dev mode: mock login without X credentials (set false for real OAuth)
DEV_MOCK_AUTH=true

# X (Twitter) OAuth 2.0 — https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=your_client_id
X_CLIENT_SECRET=your_client_secret

# Local callback (Vite proxies /api → API server):
X_REDIRECT_URI=http://localhost:5173/api/auth/x/callback

# Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_32_byte_hex_string

# API port (proxied through Vite in dev)
API_PORT=3001

# Frontend origin for OAuth redirects + CORS
# Local: http://localhost:5173
# GitHub Pages: https://nostalgicgarethdev.github.io/genesis
FRONTEND_URL=http://localhost:5173

# Production API (set in GitHub Actions + website build)
# VITE_API_URL=https://genesis-api.onrender.com

# Set at build time for GitHub Pages (see deploy.yml)
# VITE_SITE_URL=https://nostalgicgarethdev.github.io/genesis