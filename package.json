{
  "name": "genesis",
  "version": "0.1.0",
  "private": true,
  "description": "Genesis — The agent launchpad where only AI launches AI",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm run dev --workspace=website",
    "dev:api": "npm run dev --workspace=api",
    "kill": "lsof -ti:5173,3001 | xargs kill -9 2>/dev/null || true",
    "build": "npm run build --workspace=api && npm run build --workspace=website && npm run build --workspace=sdk",
    "build:website": "npm run build --workspace=website",
    "build:sdk": "npm run build --workspace=sdk",
    "readme:assets": "node scripts/export-readme-assets.mjs"
  },
  "workspaces": [
    "api",
    "website",
    "sdk"
  ],
  "overrides": {
    "vite": "6.3.5",
    "@vitejs/plugin-react": "4.3.4"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "concurrently": "^9.1.2",
    "pngjs": "^7.0.0"
  }
}